@model WorkOrderView

<h2>Delete Work Order</h2>

<div class="alert alert-danger">
    <strong>Are you sure you want to delete this Work Order?</strong>
</div>

<h4>Work Order Information</h4>
<table class="table table-bordered">
    <tr>
        <th>Customer</th>
        <td>@Model.WorkOrder.CustomerId</td>
    </tr>
    <tr>
        <th>Vehicle</th>
        <td>@Model.WorkOrder.VehicleId</td>
    </tr>
    <tr>
        <th>Issue Reported</th>
        <td>@Model.WorkOrder.IssueReported</td>
    </tr>
    <tr>
        <th>Service Type</th>
        <td>@Model.WorkOrder.ServiceType</td>
    </tr>
    <tr>
        <th>Status</th>
        <td>@Model.WorkOrder.Status</td>
    </tr>
    <tr>
        <th>Comments</th>
        <td>@Model.WorkOrder.Comments</td>
    </tr>
</table>

<h4>Work Order Details</h4>

@if (Model.Details != null && Model.Details.Any())
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Line</th>
                <th>Description</th>
                <th>Cost</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var d in Model.Details)
            {
                <tr>
                    <td>@d.Line</td>
                    <td>@d.Description</td>
                    <td>@d.Cost</td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <p>No details found for this Work Order.</p>
}

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="WorkOrder.Id" />

    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>
